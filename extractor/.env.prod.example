# =============================================================
# Extractor — Production Environment Variables
# Sao chép file này thành .env.prod và điền giá trị thực tế
# KHÔNG commit .env.prod vào git
# =============================================================

# --- OPERA Cloud API Credentials ---
OPERA_CLIENT_ID=your_client_id_here
OPERA_CLIENT_SECRET=your_client_secret_here
OPERA_APP_KEY=your_app_key_here
OPERA_BASE_URL=https://your-opera-base-url.oraclecloud.com
OPERA_TOKEN_URL=https://your-opera-base-url.oraclecloud.com/oauth/v1/tokens
OPERA_HOTEL_ID=your_hotel_id
OPERA_SCOPE=urn:opc:hgbu:ws:__myscopes__
OPERA_ENTERPRISE_ID=your_enterprise_id

# --- PostgreSQL (native trên host server) ---
# Dùng host.docker.internal để container kết nối vào PostgreSQL native trên server
POSTGRES_USER=eras_user
POSTGRES_PASSWORD=your_strong_password_here
POSTGRES_DB=erg_opera_data
DATABASE_URL=postgresql://eras_user:your_strong_password_here@host.docker.internal:5432/erg_opera_data
