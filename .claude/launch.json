{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "figma-mcp",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["figma-mcp-express"],
      "port": 3001
    },
    {
      "name": "dashboard",
      "runtimeExecutable": "streamlit",
      "runtimeArgs": ["run", "dashboard/app.py", "--server.address=0.0.0.0", "--server.port=8510"],
      "port": 8510,
      "autoPort": true
    },
    {
      "name": "executive",
      "runtimeExecutable": "streamlit",
      "runtimeArgs": ["run", "dashboard/executive/app.py", "--server.address=0.0.0.0", "--server.port=8511"],
      "port": 8511,
      "autoPort": false
    }
  ]
}
